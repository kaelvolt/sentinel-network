{
  "name": "@kael/api",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "worker:dev": "tsx watch src/worker/index.ts"
  },
  "dependencies": {
    "@kael/analysis": "workspace:*",
    "@kael/core": "workspace:*",
    "@kael/shared": "workspace:*",
    "@kael/sources": "workspace:*",
    "@kael/storage": "workspace:*",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.0.1",
    "fastify": "^4.28.0",
    "fastify-plugin": "^4.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@kael/tsconfig": "workspace:*",
    "@types/node": "^20.10.5",
    "tsx": "^4.19.0",
    "typescript": "^5.4.5",
    "vitest": "^2.0.0"
  }
}
