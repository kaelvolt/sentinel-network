# Database
DATABASE_URL=postgresql://kael:kaelpass@localhost:5432/kael_platform
DB_USER=kael
DB_PASSWORD=kaelpass
DB_NAME=kael_platform
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# API
API_PORT=3001
API_URL=http://localhost:3001

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001
WEB_PORT=3000

# Worker
WORKER_CONCURRENCY=5

# Kael Runtime
MAX_STEPS_PER_CYCLE=10
CYCLE_INTERVAL_MS=60000
AUTO_GENERATE_DIGESTS=true
ENABLE_TRACING=true

# LLM Configuration
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4
API_KEY=your_api_key_here
MODEL_BASE_URL=
MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=2000

# Alternative providers (uncomment to use):
# MODEL_PROVIDER=anthropic
# MODEL_NAME=claude-3-opus-20240229
# API_KEY=your_anthropic_key

# MODEL_PROVIDER=kimi
# MODEL_NAME=kimi-k2-5
# API_KEY=your_kimi_key
# MODEL_BASE_URL=https://api.moonshot.cn/v1

# Environment
NODE_ENV=development
